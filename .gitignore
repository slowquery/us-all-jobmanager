*.tmp
*.temp
tmp/

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.swp

# Test / coverage
coverage/
.nyc_output/

# GJC session-scoped runtime state (NOT governance artifacts).
# Keep committed: .gjc/rules/, .gjc/agents/, .gjc/config.yml (governance).
# Ignore: per-session plans/state/ultragoal ledgers (runtime, session-scoped).
.gjc/_session-*/
.gjc/state/
.gjc/plans/
.gjc/ultragoal/
