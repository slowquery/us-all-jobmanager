# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build output
dist/
build/
*.tsbuildinfo

# Env / secrets
.env
.env.*
!.env.example
*.pem

# Logs
logs.txt
logs/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

