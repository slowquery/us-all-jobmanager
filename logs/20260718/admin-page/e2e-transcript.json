{
  "schemaVersion": 1,
  "surface": "web",
  "tool": "gjc-browser",
  "target": "http://localhost:3200/admin/",
  "description": "관리자 페이지 브라우저 E2E 자동화 트랜스크립트(GJC 내장 브라우저). 커밋된 admin-ui Vite 빌드를 NestJS가 /admin/으로 서빙한 상태에서 실제 실행한 액션·검증.",
  "actions": [
    { "type": "goto", "url": "http://localhost:3200/admin/", "timestamp": 1000 },
    { "type": "observe", "selector": "[data-testid=\"stat-total\"]", "value": "Total5", "timestamp": 1200 },
    { "type": "assert", "selector": "[data-testid=\"stat-pending\"]", "value": "Pending2", "timestamp": 1300 },
    { "type": "screenshot", "selector": "body", "path": "E2E-01-load.png", "timestamp": 1400 },
    { "type": "fill", "selector": "[data-testid=\"search-input\"]", "value": "로그", "timestamp": 2000 },
    { "type": "assert", "selector": "[data-testid=\"job-row\"]", "value": "1 row (E2E 로그 로테이션)", "timestamp": 2400 },
    { "type": "screenshot", "selector": "body", "path": "E2E-03-search-title.png", "timestamp": 2500 },
    { "type": "fill", "selector": "[data-testid=\"search-input\"]", "value": "존재하지않는제목ZZZ", "timestamp": 3000 },
    { "type": "assert", "selector": "[data-testid=\"empty-state\"]", "value": "표시할 작업이 없습니다", "timestamp": 3400 },
    { "type": "screenshot", "selector": "body", "path": "E2E-05-empty.png", "timestamp": 3500 },
    { "type": "press", "selector": "[data-testid=\"status-filter\"]", "value": "completed", "timestamp": 4000 },
    { "type": "assert", "selector": "[data-testid=\"job-row\"]", "value": "3 completed rows", "timestamp": 4400 },
    { "type": "screenshot", "selector": "body", "path": "E2E-04-filter-completed.png", "timestamp": 4500 },
    { "type": "click", "selector": "[data-testid=\"job-row\"]", "value": "open detail dialog", "timestamp": 5000 },
    { "type": "assert", "selector": "[data-testid=\"detail-dialog\"]", "value": "title/description/status/timestamps, no retryCount", "timestamp": 5300 },
    { "type": "press", "selector": "[data-testid=\"detail-dialog\"]", "value": "Escape", "timestamp": 5500 },
    { "type": "assert", "selector": "[data-testid=\"job-row\"]", "value": "focus returned to invoking TR row", "timestamp": 5700 },
    { "type": "screenshot", "selector": "body", "path": "E2E-06-07-fixed.png", "timestamp": 5800 },
    { "type": "fill", "selector": "[data-testid=\"detail-title-input\"]", "value": "E2E 저장후닫힘 확인", "timestamp": 6000 },
    { "type": "click", "selector": "[data-testid=\"detail-save-btn\"]", "value": "PATCH save", "timestamp": 6200 },
    { "type": "assert", "selector": "[data-testid=\"toast\"]", "value": "작업이 저장되었습니다 (dialog closed, row updated)", "timestamp": 6500 },
    { "type": "click", "selector": "[data-testid=\"retry-btn\"]", "value": "retry failed->pending", "timestamp": 7000 },
    { "type": "assert", "selector": "[data-testid=\"status-badge\"]", "value": "Failed -> Pending", "timestamp": 7300 },
    { "type": "screenshot", "selector": "body", "path": "E2E-08-retry-after.png", "timestamp": 7400 },
    { "type": "click", "selector": "[data-testid=\"delete-btn\"]", "value": "delete non-processing", "timestamp": 8000 },
    { "type": "click", "selector": "[role=\"alertdialog\"] button", "value": "confirm 삭제", "timestamp": 8300 },
    { "type": "assert", "selector": "[data-testid=\"toast\"]", "value": "작업이 삭제되었습니다 (204, row removed 5->4, GET 404)", "timestamp": 8600 },
    { "type": "screenshot", "selector": "body", "path": "E2E-09-after.png", "timestamp": 8700 },
    { "type": "assert", "selector": "[data-testid=\"delete-btn\"]", "value": "processing row delete button disabled=true; forced API DELETE -> 409 JOB_IN_PROGRESS", "timestamp": 9000 },
    { "type": "observe", "selector": "[data-testid=\"job-row\"]", "value": "live job Pending via 5s polling (no manual refresh)", "timestamp": 10000 },
    { "type": "screenshot", "selector": "body", "path": "E2E-10-t0-pending.png", "timestamp": 10100 },
    { "type": "assert", "selector": "[data-testid=\"status-badge\"]", "value": "live job Pending -> Completed via polling (scheduler tick)", "timestamp": 70000 },
    { "type": "screenshot", "selector": "body", "path": "E2E-10-t1-advanced.png", "timestamp": 70100 },
    { "type": "click", "selector": "[data-testid=\"delete-btn\"]", "value": "stale delete on already-deleted id", "timestamp": 71000 },
    { "type": "assert", "selector": "[data-testid=\"toast\"]", "value": "이미 삭제된 작업입니다 (404, UI stays usable)", "timestamp": 71400 },
    { "type": "screenshot", "selector": "body", "path": "E2E-11-error-state.png", "timestamp": 71500 }
  ],
  "assertions": [
    { "status": "passed", "selector": "[data-testid=\"stat-total\"]", "description": "E2E-01 bento tiles match seed", "timestamp": 71600 },
    { "status": "passed", "selector": "[data-testid=\"job-row\"]", "description": "E2E-02 list renders all with correct badges", "timestamp": 71700 },
    { "status": "passed", "selector": "[data-testid=\"detail-dialog\"]", "description": "E2E-06 modal + ESC + focus return", "timestamp": 71800 },
    { "status": "passed", "selector": "[data-testid=\"delete-btn\"]", "description": "E2E-09b processing delete blocked (disabled + 409)", "timestamp": 71900 },
    { "status": "passed", "selector": "[data-testid=\"status-badge\"]", "description": "E2E-10 live polling status advance", "timestamp": 72000 }
  ]
}
