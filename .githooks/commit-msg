#!/usr/bin/env bash
set -euo pipefail
msg_file="$1"
subject="$(head -n1 "$msg_file")"
# 생성 subject(merge/revert/autosquash)는 예외 — --no-verify 유도 방지.
if printf '%s' "$subject" | grep -Eq '^(Merge |Revert |fixup! |squash! |amend! )'; then
  exit 0
fi
# Conventional Commits 형식 (타입 프리픽스는 영문).
if ! printf '%s' "$subject" | grep -Eq '^(feat|fix|chore|docs|style|refactor|test)(\([a-z0-9._/-]+\))?: .+'; then
  echo "governance/commit-msg: 제목은 Conventional Commits '<type>(scope)?: 설명' 형식이어야 합니다 (feat|fix|chore|docs|style|refactor|test) (Rule 7)." >&2
  exit 1
fi
# 커밋 메시지 내용은 한글로 작성 (Rule 7 / Rule 9). 타입 프리픽스만 영문, 설명에 한글 필수.
desc="$(printf '%s' "$subject" | sed -E 's/^(feat|fix|chore|docs|style|refactor|test)(\([a-z0-9._/-]+\))?: //')"
if ! printf '%s' "$desc" | grep -Pq '[\x{ac00}-\x{d7a3}]'; then
  echo "governance/commit-msg: 커밋 제목 설명은 한글로 작성하세요 (Conventional 타입 프리픽스만 영문) (Rule 7)." >&2
  exit 1
fi
# SemVer sync: 'version: X.Y.Z' 트레일러가 있으면 package.json version과 바이트 일치.
ver_line="$(grep -E '^version:[[:space:]]*[0-9]+\.[0-9]+\.[0-9]+[[:space:]]*$' "$msg_file" | tail -n1 || true)"
if [ -n "$ver_line" ]; then
  declared="$(printf '%s' "$ver_line" | sed -E 's/^version:[[:space:]]*//; s/[[:space:]]*$//')"
  pkg="$(node -p "require('./package.json').version" 2>/dev/null || true)"
  if [ -z "$pkg" ]; then
    echo "governance/commit-msg: package.json version을 읽을 수 없습니다 (node 미설치?); '$declared' SemVer 동기화 검사 건너뜀." >&2
  elif [ "$declared" != "$pkg" ]; then
    echo "governance/commit-msg: 버전 트레일러 '$declared' != package.json version '$pkg' (Rule 7 SemVer 동기화)." >&2
    exit 1
  fi
fi
# 릴리스 subject 형식: '<type>: (X.Y.Z) 설명'의 괄호 버전이 있으면 package.json version과 바이트 일치(Rule 7 머지 subject).
# 형식(정규식)을 바꾸면 .github/workflows/ci.yml의 '머지 subject 릴리스 형식 검증'도 함께 동기화할 것.
subj_ver="$(printf '%s' "$desc" | sed -nE 's/^\(([0-9]+\.[0-9]+\.[0-9]+)\) .*/\1/p')"
if [ -n "$subj_ver" ]; then
  pkg="$(node -p "require('./package.json').version" 2>/dev/null || true)"
  if [ -z "$pkg" ]; then
    echo "governance/commit-msg: package.json version을 읽을 수 없어 subject 버전 '($subj_ver)' 검사를 건너뜁니다." >&2
  elif [ "$subj_ver" != "$pkg" ]; then
    echo "governance/commit-msg: subject 버전 '($subj_ver)' != package.json version '$pkg' (Rule 7 릴리스 subject 형식)." >&2
    exit 1
  fi
fi
exit 0
