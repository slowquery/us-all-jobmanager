#!/usr/bin/env bash
set -euo pipefail
# stdin lines: <local ref> <local sha> <remote ref> <remote sha>
while read -r localref localsha remoteref remotesha; do
  if [ "$remoteref" = "refs/heads/master" ]; then
    echo "governance/pre-push: pushing to 'master' is refused (hard backstop, incl. ff-merge/rebase). Open a squash PR on GitHub (Rule 7)." >&2
    exit 1
  fi
done
exit 0
